<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ============ MAIN CONTENT ============ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark">

        <com.family.hippomuncher.GameSurfaceView
            android:id="@+id/gameSurface"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <androidx.camera.view.PreviewView
            android:id="@+id/pipPreview"
            android:layout_width="160dp"
            android:layout_height="120dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@color/bg_drawer"
            android:elevation="6dp" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="@android:color/transparent"
            android:contentDescription="Menu"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/neon_cyan"
            android:elevation="6dp" />

        <LinearLayout
            android:id="@+id/permissionOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_dark"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:elevation="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📷" android:textSize="64sp" />
            <Button android:id="@+id/btnGrantCamera" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/grant_camera" />
        </LinearLayout>
    </FrameLayout>

    <!-- ============ SIDE DRAWER ============ -->
    <FrameLayout
        android:id="@+id/drawerChild"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:clickable="true"
        android:focusable="true"
        android:elevation="100dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_drawer" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Hippo Muncher"
                    android:textColor="@color/neon_cyan"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:paddingBottom="24dp" />

                <Button
                    android:id="@+id/btnPlay"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="@string/menu_play"
                    android:textColor="@color/neon_lime"
                    android:textSize="18sp"
                    android:minHeight="64dp" />

                <Button
                    android:id="@+id/btnRecalibrate"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="@string/menu_recalibrate"
                    android:textColor="@color/neon_yellow"
                    android:textSize="18sp"
                    android:minHeight="64dp" />

                <Button
                    android:id="@+id/btnResetScore"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="@string/menu_reset_score"
                    android:textColor="@color/neon_magenta"
                    android:textSize="18sp"
                    android:minHeight="64dp" />

                <Button
                    android:id="@+id/btnQuit"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:text="@string/menu_quit"
                    android:textColor="@color/neon_cyan"
                    android:textSize="18sp"
                    android:minHeight="64dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="DIFFICULTY"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnEasy" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:text="EASY" android:textSize="12sp" />
                    <Button android:id="@+id/btnMedium" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:text="MED" android:textSize="12sp" />
                    <Button android:id="@+id/btnHard" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_margin="2dp" android:text="HARD" android:textSize="12sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="80dp" />

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>
